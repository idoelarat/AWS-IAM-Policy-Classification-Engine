    {
        "original_policy": {
            "Version": "2012-10-17",
            "Statement": [
                {
                    "Effect": "Allow",
                    "Action": "s3:*",
                    "Resource": "*"
                }
            ]
        },
        "analysis": {
            "classification": "WEAK",
            "provider": "AWS",
            "reason": "The policy grants 's3:*' permissions on all resources without any conditions. This violates the Principle of Least Privilege by allowing excessive actions and exposing resources indiscriminately."
        },
        "remediation": {
            "fixed_policy": {
                "Version": "2012-10-17",
                "Statement": [
                    {
                        "Effect": "Allow",
                        "Action": [
                            "s3:ListBucket"
                        ],
                        "Resource": "arn:aws:s3:::example-bucket",
                        "Condition": {
                            "IpAddress": {
                                "aws:SourceIp": "192.0.2.0/24"
                            }
                        }
                    },
                    {
                        "Effect": "Allow",
                        "Action": [
                            "s3:GetObject",
                            "s3:PutObject"
                        ],
                        "Resource": "arn:aws:s3:::example-bucket/*",
                        "Condition": {
                            "IpAddress": {
                                "aws:SourceIp": "192.0.2.0/24"
                            }
                        }
                    }
                ]
            },
            "explanation": "This revised policy ensures least privilege by restricting the permissions to only necessary S3 actions. 's3:ListBucket' is limited to the bucket itself, and 's3:GetObject' and 's3:PutObject' are limited to objects within the specified bucket. Access is further restricted by an IP address condition, limiting actions to a specific IP range, thereby providing additional security by preventing unauthorized access from unknown IPs."
        },
        "metadata": {
            "filename": "aws_weak_s3.json",
            "processing_time_sec": 6.71
        }
    },
    {
        "original_policy": {
            "properties": {
                "roleName": "Custom Wildcard Admin",
                "description": "Too much power",
                "assignableScopes": [
                    "/"
                ],
                "permissions": [
                    {
                        "actions": [
                            "*"
                        ],
                        "notActions": [],
                        "dataActions": [],
                        "notDataActions": []
                    }
                ]
            }
        },
        "analysis": {
            "classification": "WEAK",
            "provider": "AZURE",
            "reason": "The policy has 'assignableScopes' set to root '/' and uses wildcard '*' in 'actions', granting excessive permissions that allow for potential lateral movement and lack granular scope control."
        },
        "remediation": {
            "fixed_policy": {
                "properties": {
                    "roleName": "Custom Limited Admin",
                    "description": "Reduced permissions for security",
                    "assignableScopes": [
                        "/subscriptions/your-subscription-id"
                    ],
                    "permissions": [
                        {
                            "actions": [
                                "Microsoft.Storage/storageAccounts/read",
                                "Microsoft.Compute/virtualMachines/read"
                            ],
                            "notActions": [],
                            "dataActions": [],
                            "notDataActions": []
                        }
                    ]
                }
            },
            "explanation": "The assignableScopes have been restricted to a specific subscription rather than the root to prevent the role from being used across all resources indiscriminately. The 'actions' field has been updated to specify only the necessary permissions required for the role. This ensures adherence to the principle of least privilege, reducing the risk of lateral movement and unauthorized access in the environment."
        },
        "metadata": {
            "filename": "azure_weak_rbac.json",
            "processing_time_sec": 7.01
        }
    },
    {
        "original_policy": {
