    {
        "original_policy": {
            "Version": "2012-10-17",
            "Statement": [
                {
                    "Effect": "Allow",
                    "Action": "s3:*",
                    "Resource": "*"
                }
            ]
        },
        "analysis": {
            "classification": "WEAK",
            "provider": "AWS",
            "reason": "The policy allows all actions ('*') on all S3 resources ('*'), which indicates excessive permissions."
        },
        "remediation": {
            "fixed_policy": {
                "Version": "2012-10-17",
                "Statement": [
                    {
                        "Effect": "Allow",
                        "Action": [
                            "s3:PutObject",
                            "s3:GetObject",
                            "s3:ListBucket"
                        ],
                        "Resource": [
                            "arn:aws:s3:::example-bucket",
                            "arn:aws:s3:::example-bucket/*"
                        ]
                    }
                ]
            },
            "explanation": "The fixed policy follows the principle of least privilege by specifying only the necessary actions: 's3:PutObject' for uploading, 's3:GetObject' for downloading, and 's3:ListBucket' for listing the objects in the bucket. The resources are restricted to a specific bucket, 'example-bucket', rather than allowing access to all S3 resources."
        },
        "metadata": {
            "filename": "aws_weak_s3.json",
            "processing_time_sec": 3.96
        }
    },
