    {
        "original_policy": {
            "Version": "2012-10-17",
            "Statement": [
                {
                    "Effect": "Allow",
                    "Action": [
                        "s3:GetObject",
                        "s3:ListBucket"
                    ],
                    "Resource": [
                        "arn:aws:s3:::production-data-shared",
                        "arn:aws:s3:::production-data-shared/*"
                    ]
                }
            ]
        },
        "analysis": {
            "classification": "STRONG",
            "provider": "AWS",
            "reason": "The policy adheres to PoLP by allowing only specific actions (s3:GetObject, s3:ListBucket) on specific resources without excessive permissions or wildcards."
